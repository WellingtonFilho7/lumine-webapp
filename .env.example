# Supabase Auth
REACT_APP_SUPABASE_URL=https://seu-projeto.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sua_chave_publica_supabase

# API
# Opcional: se omitir, o frontend usa https://lumine-api.vercel.app/api
REACT_APP_API_BASE_URL=https://lumine-api.vercel.app/api

# Feature flags
REACT_APP_REQUIRE_LOGIN=true
REACT_APP_FINANCE_MODULE_ENABLED=true
REACT_APP_MOBILE_UI_V2=true
REACT_APP_ONLINE_ONLY=true
